{
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "catppuccin-mocha",
    "catppuccin.italicKeywords": false,
    "python.experiments.optOutFrom": [],
    "python.useEnvironmentsExtension": true,
    "python.defaultInterpreterPath": "/usr/bin/python",
    "git.autofetch": true,
    "git.confirmSync": false,
    "errorLens.followCursorMore": 15,
    "errorLens.followCursor": "activeLine",
    "editor.fontSize": 16,
    "debugpy.debugJustMyCode": false,
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "editor.cursorBlinking": "smooth",
    "terminal.integrated.cursorBlinking": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "editor.minimap.enabled": false,
    "c-cpp-flylint.run": "onType",
    "c-cpp-flylint.language": "c",
    "editor.renderWhitespace": "none",
    "makefile.configureOnOpen": true,
    "c-cpp-flylint.cppcheck.extraArgs": [],
    "c-cpp-flylint.flexelint.enable": false,
    "c-cpp-flylint.flawfinder.enable": false,
    "c-cpp-flylint.lizard.enable": false,
    "c-cpp-flylint.clang.enable": false,
    "editor.cursorSurroundingLines": 1,
    "editor.fontFamily": "JetBrains Mono",
    "redhat.telemetry.enabled": false,
    "java.checkstyle.configuration": "/mnt/fast/Documents/School/Freshman/CSC216/csc_checkstyle.xml",
    "javaPMD.commandBufferSize": 1,
    "javaPMD.rulesets": [
        "/mnt/fast/Documents/School/Freshman/CSC216/csc_pmd.xml"
    ],
    "javaPMD.runOnFileChange": true,
    "git.enableSmartCommit": true
}
